        button:hover { background: #fff9e6; border-color: var(--gold); }
        .next-btn { background: var(--primary) !important; color: white !important; margin-top: 20px; width: 100%; border: none; }
        
        .feedback { font-weight: bold; margin-top: 15px; padding: 12px; border-radius: 8px; display: none; font-size: 14px; line-height: 1.6; }
        .correct { background: #e6fffa; color: #234e52; border: 1px solid #b2f5ea; }
        .wrong { background: #fff5f5; color: #822727; border: 1px solid #feb2b2; }

        .cert-box { border: 4px solid var(--gold); padding: 20px; background: #fffdf5; text-align: center; border-radius: 15px; }
        textarea { width: 100%; height: 80px; padding: 10px; border-radius: 8px; border: 1px solid #ccc; margin-top: 10px; box-sizing: border-box; font-size: 16px; }
    </style>
</head>
